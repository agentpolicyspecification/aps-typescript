{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://agentpolicyspecification.github.io/schemas/v0.1.0/transports/http.schema.json",
    "title": "HttpPolicy",
    "description": "A policy evaluated by a remote HTTP server. The server receives the full context and returns a PolicyDecision.",
    "type": "object",
    "required": [
        "transport",
        "url"
    ],
    "additionalProperties": false,
    "properties": {
        "transport": {
            "const": "http"
        },
        "url": {
            "type": "string",
            "format": "uri",
            "description": "The endpoint to POST the evaluation request to"
        },
        "headers": {
            "type": "object",
            "description": "HTTP headers to include in every request. Values support ${ENV_VAR} interpolation.",
            "additionalProperties": {
                "type": "string"
            }
        },
        "applies_to": {
            "$ref": "../shared/applies-to.schema.json"
        }
    }
}